<section class="page-width page-content">
  <header class="page-content__header">
    <p class="eyebrow">Lorez Beauty</p>
    <h1 class="heading-lg">{{ page.title }}</h1>
    {%- if page.handle == 'contact' -%}
      <p class="page-content__intro">Need help with samples, private label development or product launch planning? Tell us what you're building and we’ll get back to you shortly.</p>
    {%- elsif page.handle == 'faq' -%}
      <p class="page-content__intro">Find answers about customization, manufacturing, packaging and launch support for your whitening brand.</p>
    {%- endif -%}
  </header>
  <div class="page-content__body rte">
    {{ page.content }}
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}

<section class="services">
  <div class="services__header">
    {%- if section.settings.title != blank -%}
      <h2 class="heading-lg">{{ section.settings.title }}</h2>
    {%- endif -%}
  </div>
  <div class="services__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="service-card" {{ block.shopify_attributes }}>
        <div class="service-card__icon">
          {%- case block.settings.icon -%}
            {%- when 'gift' -%}
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="8" y="20" width="32" height="22" rx="1"/>
                <path d="M24 20V42M8 26h32"/>
                <path d="M24 20c-4 0-8-2-8-6s4-4 8-4 8 0 8 4-4 6-8 6z"/>
                <path d="M24 10v10"/>
              </svg>
            {%- when 'sample' -%}
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="14" y="8" width="20" height="32" rx="2"/>
                <path d="M20 16h8M20 22h8M20 28h5"/>
              </svg>
            {%- when 'shipping' -%}
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M4 32h32l4-12H8z"/>
                <circle cx="14" cy="36" r="3"/>
                <circle cx="30" cy="36" r="3"/>
                <path d="M36 20V12H20"/>
              </svg>
            {%- else -%}
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="24" cy="24" r="16"/>
              </svg>
          {%- endcase -%}
        </div>
        <h3 class="service-card__title">{{ block.settings.title }}</h3>
        {%- if block.settings.text_mx != blank -%}
          <p class="service-card__text" data-market-copy data-es="{{ block.settings.text | escape }}" data-mx="{{ block.settings.text_mx | escape }}">{{ block.settings.text }}</p>
        {%- elsif block.settings.text != blank -%}
          <p class="service-card__text">{{ block.settings.text }}</p>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Services",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Lorez Beauty Services"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "gift", "label": "Gift" },
            { "value": "sample", "label": "Sample" },
            { "value": "shipping", "label": "Shipping" }
          ],
          "default": "gift"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The art of gifting"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Exclusive gift wrapping for every order"
        },
        {
          "type": "text",
          "id": "text_mx",
          "label": "Description (México)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "gift",
            "title": "The art of gifting",
            "text": "Exclusive gift wrapping for every order"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "sample",
            "title": "Samples & miniatures",
            "text": "Complimentary samples with every purchase"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "shipping",
            "title": "Free shipping",
            "text": "On all orders over €50"
          }
        }
      ]
    }
  ]
}
{% endschema %}

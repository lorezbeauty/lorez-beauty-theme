<section class="ugc-proof" id="ugc-proof-{{ section.id }}">
  <div class="ugc-proof__inner">
    <header class="ugc-proof__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow ugc-proof__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title_before != blank or section.settings.title_accent != blank -%}
        <h2 class="heading-lg ugc-proof__title">
          {{- section.settings.title_before -}}
          {%- if section.settings.title_accent != blank -%}
            <span class="ugc-proof__accent">{{ section.settings.title_accent }}</span>
          {%- endif -%}
          {{- section.settings.title_after -}}
        </h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ugc-proof__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="ugc-proof__track" tabindex="0" role="region" aria-label="{{ section.settings.title_accent | default: 'Customer reviews' }}">
        {%- for block in section.blocks -%}
          <article class="ugc-proof__card" {{ block.shopify_attributes }}>
            <div class="ugc-proof__photo">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  class: 'ugc-proof__img',
                  sizes: '(max-width: 640px) 78vw, 280px',
                  alt: block.settings.author | append: ' — Lorez Beauty customer'
                }}
              {%- elsif block.settings.asset_image != blank -%}
                <img
                  class="ugc-proof__img"
                  src="{{ block.settings.asset_image | asset_url }}"
                  alt="{{ block.settings.author | escape }} — Lorez Beauty customer"
                  loading="lazy"
                  width="400"
                  height="520"
                >
              {%- elsif block.settings.fallback_image_url != blank -%}
                <img
                  class="ugc-proof__img"
                  src="{{ block.settings.fallback_image_url }}"
                  alt="{{ block.settings.author | escape }} — Lorez Beauty customer review"
                  loading="lazy"
                  width="400"
                  height="520"
                >
              {%- else -%}
                <div class="ugc-proof__placeholder ugc-proof__placeholder--{{ forloop.index }}" aria-hidden="true"></div>
              {%- endif -%}
              <div class="ugc-proof__gradient" aria-hidden="true"></div>
              <div class="ugc-proof__content">
                <p class="ugc-proof__stars" aria-label="5 out of 5 stars">★★★★★</p>
                {%- if block.settings.quote != blank -%}
                  <blockquote class="ugc-proof__quote">"{{ block.settings.quote }}"</blockquote>
                {%- endif -%}
                <footer class="ugc-proof__footer">
                  {%- if section.settings.badge_label != blank -%}
                    <span class="ugc-proof__verified">
                      <svg class="ugc-proof__verified-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <circle cx="7" cy="7" r="7" fill="currentColor"/>
                        <path d="M4 7l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      {{ section.settings.badge_label }}
                    </span>
                  {%- endif -%}
                  <cite class="ugc-proof__author">
                    <strong>{{ block.settings.author }}</strong>
                    {%- if block.settings.role != blank -%}
                      <span>{{ block.settings.role }}</span>
                    {%- endif -%}
                  </cite>
                </footer>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Social proof UGC",
  "tag": "section",
  "class": "section-ugc-proof",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real results" },
    { "type": "text", "id": "title_before", "label": "Title (before accent)", "default": "What " },
    { "type": "text", "id": "title_accent", "label": "Title accent (colored)", "default": "Daily Smile Lovers" },
    { "type": "text", "id": "title_after", "label": "Title (after accent)", "default": " Are Saying" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Join thousands of smile lovers discovering gentle PAP+ whitening — no peroxide, no sensitivity." },
    { "type": "text", "id": "badge_label", "label": "Card badge", "default": "Lorez customer", "info": "Use \"Lorez customer\" for illustrative UGC. Switch to \"Verified buyer\" only with real Judge.me reviews." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "UGC review card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Lifestyle photo", "info": "Replace with real UGC from Judge.me or creator shoots." },
        { "type": "text", "id": "asset_image", "label": "Theme asset filename", "info": "e.g. ugc-review-1.jpg — used if no image picker upload." },
        { "type": "text", "id": "fallback_image_url", "label": "Fallback image URL", "info": "Used if neither image picker nor theme asset is set." },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Name", "default": "Sarah M." },
        { "type": "text", "id": "role", "label": "Role / context", "default": "Busy Professional" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof UGC",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "asset_image": "ugc-review-1.jpg",
            "quote": "I drink three coffees before lunch — my teeth used to show it. Two weeks with the PAP+ strips and colleagues keep asking what changed. No sensitivity at all.",
            "author": "Emma T.",
            "role": "Coffee lover"
          }
        },
        {
          "type": "review",
          "settings": {
            "asset_image": "ugc-review-2.jpg",
            "quote": "Six weeks until the wedding and I refused harsh peroxide kits. The Complete Smile Bundle fits my morning routine — brighter smile, zero drama.",
            "author": "Sofia K.",
            "role": "Bride-to-be"
          }
        },
        {
          "type": "review",
          "settings": {
            "asset_image": "ugc-review-3.jpg",
            "quote": "My barista friends roast me for ordering doubles. These strips stay put while I catch up on emails. Gradual brightening without that chemical sting.",
            "author": "Marco L.",
            "role": "Coffee lover"
          }
        },
        {
          "type": "review",
          "settings": {
            "asset_image": "ugc-review-4.jpg",
            "quote": "School run, meetings, dinner — zero time for salon visits. Twenty minutes on the couch with Lorez and I'm done. My kids noticed I'm smiling more.",
            "author": "Anna W.",
            "role": "Working mom"
          }
        },
        {
          "type": "review",
          "settings": {
            "asset_image": "ugc-review-5.jpg",
            "quote": "Coconut mint patches are my Sunday reset. Fresh breath, gradual brightening, and none of that harsh peroxide burn from old kits.",
            "author": "Lisa V.",
            "role": "Self-care Sunday"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section class="ugc-proof" id="ugc-proof-{{ section.id }}">
  <div class="ugc-proof__inner">
    <header class="ugc-proof__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow ugc-proof__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title_before != blank or section.settings.title_accent != blank -%}
        <h2 class="heading-lg ugc-proof__title">
          {{- section.settings.title_before -}}
          {%- if section.settings.title_accent != blank -%}
            <span class="ugc-proof__accent">{{ section.settings.title_accent }}</span>
          {%- endif -%}
          {{- section.settings.title_after -}}
        </h2>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="ugc-proof__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="ugc-proof__track" tabindex="0" role="region" aria-label="{{ section.settings.title_accent | default: 'Customer reviews' }}">
        {%- for block in section.blocks -%}
          <article class="ugc-proof__card" {{ block.shopify_attributes }}>
            <div class="ugc-proof__photo">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  class: 'ugc-proof__img',
                  sizes: '(max-width: 640px) 78vw, 280px',
                  alt: block.settings.author | append: ' — Lorez Beauty customer review'
                }}
              {%- elsif block.settings.fallback_image_url != blank -%}
                <img
                  class="ugc-proof__img"
                  src="{{ block.settings.fallback_image_url }}"
                  alt="{{ block.settings.author | escape }} — Lorez Beauty customer review"
                  loading="lazy"
                  width="400"
                  height="520"
                >
              {%- else -%}
                <div class="ugc-proof__placeholder ugc-proof__placeholder--{{ forloop.index }}" aria-hidden="true"></div>
              {%- endif -%}
              <div class="ugc-proof__gradient" aria-hidden="true"></div>
              <div class="ugc-proof__content">
                <p class="ugc-proof__stars" aria-label="5 out of 5 stars">★★★★★</p>
                {%- if block.settings.quote != blank -%}
                  <blockquote class="ugc-proof__quote">"{{ block.settings.quote }}"</blockquote>
                {%- endif -%}
                <footer class="ugc-proof__footer">
                  <span class="ugc-proof__verified">
                    <svg class="ugc-proof__verified-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <circle cx="7" cy="7" r="7" fill="currentColor"/>
                      <path d="M4 7l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Verified
                  </span>
                  <cite class="ugc-proof__author">
                    <strong>{{ block.settings.author }}</strong>
                    {%- if block.settings.role != blank -%}
                      <span>{{ block.settings.role }}</span>
                    {%- endif -%}
                  </cite>
                </footer>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Social proof UGC",
  "tag": "section",
  "class": "section-ugc-proof",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real results" },
    { "type": "text", "id": "title_before", "label": "Title (before accent)", "default": "What " },
    { "type": "text", "id": "title_accent", "label": "Title accent (colored)", "default": "Daily Smile Lovers" },
    { "type": "text", "id": "title_after", "label": "Title (after accent)", "default": " Are Saying" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Over 10,000+ customers have brightened their smile with Lorez Beauty — gentle PAP+ whitening, zero sensitivity." }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "UGC review card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Lifestyle photo", "info": "Replace with real UGC from Judge.me or creator shoots." },
        { "type": "text", "id": "fallback_image_url", "label": "Placeholder image URL", "info": "Used until you upload a photo in the picker above." },
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Name", "default": "Sarah M." },
        { "type": "text", "id": "role", "label": "Role / context", "default": "Busy Professional" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof UGC",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "fallback_image_url": "https://images.unsplash.com/photo-1612892487496-74d4f90acd0e?w=600&h=780&fit=crop&q=80",
            "quote": "Three coffees a day used to show on my teeth. After two weeks with the PAP+ strips, my smile looks noticeably brighter — and zero sensitivity.",
            "author": "Sarah M.",
            "role": "Busy Professional"
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image_url": "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=600&h=780&fit=crop&q=80",
            "quote": "Wedding in six weeks — I needed something gentle that actually works. The Complete Smile Bundle gave me confidence without the salon price tag.",
            "author": "Jessica T.",
            "role": "Bride-to-be"
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image_url": "https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=600&h=780&fit=crop&q=80",
            "quote": "I'm a coffee addict and my dentist noticed the difference. The strips stay put for 30 minutes while I answer emails. No sticky mess.",
            "author": "Marco L.",
            "role": "Coffee Lover"
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image_url": "https://images.unsplash.com/photo-1531746020798-e6953c6e8a04?w=600&h=780&fit=crop&q=80",
            "quote": "Finally whitening that fits between school drop-off and meetings. Twenty minutes on the couch, done. My kids even asked why I'm smiling more.",
            "author": "Emma K.",
            "role": "Working Mom"
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image_url": "https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=600&h=780&fit=crop&q=80",
            "quote": "The coconut mint patches are my Sunday ritual. Fresh breath and a gradual brightening — way better than harsh peroxide kits I tried before.",
            "author": "Lisa V.",
            "role": "Self-care Enthusiast"
          }
        }
      ]
    }
  ]
}
{% endschema %}

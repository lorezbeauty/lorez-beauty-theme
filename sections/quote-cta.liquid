<section class="quote-cta{% if section.settings.style == 'whitening' %} quote-cta--whitening{% endif %}" id="quote-cta-{{ section.id }}">
  <div class="quote-cta__inner">
    <div class="quote-cta__content">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p>{{ section.settings.description }}</p>
      {%- endif -%}
      <div class="quote-cta__features">
        {%- if section.settings.feature_1 != blank -%}<span class="quote-feature">{{ section.settings.feature_1 }}</span>{%- endif -%}
        {%- if section.settings.feature_2 != blank -%}<span class="quote-feature">{{ section.settings.feature_2 }}</span>{%- endif -%}
        {%- if section.settings.feature_3 != blank -%}<span class="quote-feature">{{ section.settings.feature_3 }}</span>{%- endif -%}
        {%- if section.settings.feature_4 != blank -%}<span class="quote-feature">{{ section.settings.feature_4 }}</span>{%- endif -%}
      </div>
      <div class="quote-cta__action">
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="quote-btn quote-btn--primary">{{ section.settings.button_text }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_text != blank -%}
          <a href="{{ section.settings.secondary_link }}" class="quote-btn quote-btn--secondary">{{ section.settings.secondary_text }}</a>
        {%- endif -%}
      </div>
    </div>
    <div class="quote-cta__visual">
      {%- if section.settings.icon != blank -%}
        <div class="quote-visual-icon">{{ section.settings.icon }}</div>
      {%- endif -%}
      {%- if section.settings.visual_text != blank -%}
        <div class="quote-visual-text">{{ section.settings.visual_text | newline_to_br }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #quote-cta-{{ section.id }}:not(.quote-cta--whitening) {
    padding: 56px var(--gutter);
    background: linear-gradient(120deg, #b84f68 0%, #d16b7b 100%);
    color: #fff;
  }

  #quote-cta-{{ section.id }}.quote-cta--whitening {
    padding: 72px var(--gutter);
  }

  #quote-cta-{{ section.id }} .quote-cta__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
  }

  @media (max-width: 768px) {
    #quote-cta-{{ section.id }} .quote-cta__inner {
      grid-template-columns: 1fr;
    }
  }

  #quote-cta-{{ section.id }} .quote-cta__content h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 12px;
    line-height: 1.15;
  }

  #quote-cta-{{ section.id }} .quote-cta__content p {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  #quote-cta-{{ section.id }} .quote-cta__features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-bottom: 24px;
  }

  #quote-cta-{{ section.id }} .quote-feature {
    font-size: 0.83rem;
    color: rgba(255, 255, 255, 0.9);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #quote-cta-{{ section.id }} .quote-feature::before {
    content: '✓';
    font-weight: 700;
  }

  #quote-cta-{{ section.id }} .quote-cta__action {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  #quote-cta-{{ section.id }} .quote-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 22px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.88rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  #quote-cta-{{ section.id }} .quote-btn--primary {
    background: #fff;
    color: #b84f68;
  }

  #quote-cta-{{ section.id }} .quote-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.2);
  }

  #quote-cta-{{ section.id }} .quote-btn--secondary {
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    color: #fff;
  }

  #quote-cta-{{ section.id }} .quote-btn--secondary:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  #quote-cta-{{ section.id }} .quote-cta__visual {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 20px;
    padding: 32px;
    text-align: center;
  }

  #quote-cta-{{ section.id }} .quote-visual-icon {
    font-size: 3rem;
    margin-bottom: 12px;
  }

  #quote-cta-{{ section.id }} .quote-visual-text {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.8;
  }
</style>

{% schema %}
{
  "name": "Request Quote CTA",
  "settings": [
    { "type": "select", "id": "style", "label": "Style", "options": [
      { "value": "default", "label": "Default" },
      { "value": "whitening", "label": "Whitening sales" }
    ], "default": "default" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to launch your whitening line?" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Connect with our team for samples, custom development and private label support." },
    { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "Free samples in 48 hours" },
    { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Custom formulation support" },
    { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Low MOQ, fast production" },
    { "type": "text", "id": "feature_4", "label": "Feature 4", "default": "Certified + compliant" },
    { "type": "text", "id": "icon", "label": "Visual icon (emoji)", "default": "📋" },
    { "type": "textarea", "id": "visual_text", "label": "Visual text", "default": "OEM / ODM Partnership Model\n\nSamples → Formulation → Packaging → Launch" },
    { "type": "text", "id": "button_text", "label": "Primary button text", "default": "Get a quote" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_text", "label": "Secondary button text", "default": "Learn about OEM/ODM" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" }
  ],
  "presets": [
    { "name": "Request Quote CTA" }
  ]
}
{% endschema %}

<!-- Contact form section for product inquiries and quotes -->
<style>
  #contact-form-{{ section.id }} {
    padding: 72px var(--gutter);
    background: linear-gradient(135deg, #fff6f8 0%, #fde1e8 100%);
  }

  #contact-form-{{ section.id }} .contact-container {
    max-width: 720px;
    margin: 0 auto;
  }

  #contact-form-{{ section.id }} .contact-header {
    text-align: center;
    margin-bottom: 40px;
  }

  #contact-form-{{ section.id }} .contact-header h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: #342125;
  }

  #contact-form-{{ section.id }} .contact-header p {
    color: #7a5d64;
    line-height: 1.7;
    font-size: 0.95rem;
  }

  #contact-form-{{ section.id }} .contact-form {
    background: #fff;
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 18px 34px rgba(123, 67, 78, 0.08);
  }

  #contact-form-{{ section.id }} .form-group {
    margin-bottom: 20px;
  }

  #contact-form-{{ section.id }} .form-group label {
    display: block;
    margin-bottom: 6px;
    font-weight: 600;
    color: #342125;
    font-size: 0.9rem;
  }

  #contact-form-{{ section.id }} .form-group input,
  #contact-form-{{ section.id }} .form-group textarea,
  #contact-form-{{ section.id }} .form-group select {
    width: 100%;
    padding: 12px;
    border: 1px solid #e8dde2;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.95rem;
    background: #fafaf9;
    transition: border-color 0.25s ease;
  }

  #contact-form-{{ section.id }} .form-group input:focus,
  #contact-form-{{ section.id }} .form-group textarea:focus,
  #contact-form-{{ section.id }} .form-group select:focus {
    outline: none;
    border-color: #c96c7e;
    background: #fff;
  }

  #contact-form-{{ section.id }} .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  #contact-form-{{ section.id }} .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 640px) {
    #contact-form-{{ section.id }} .form-row {
      grid-template-columns: 1fr;
    }
  }

  #contact-form-{{ section.id }} .contact-submit {
    background: #b84f68;
    color: #fff;
    padding: 14px 28px;
    border: none;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    width: 100%;
  }

  #contact-form-{{ section.id }} .contact-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(184, 79, 104, 0.25);
  }

  #contact-form-{{ section.id }} .contact-note {
    margin-top: 12px;
    font-size: 0.8rem;
    color: #7a5d64;
    text-align: center;
  }
</style>

<div id="contact-form-{{ section.id }}">
  <div class="contact-container">
    <div class="contact-header">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <form action="{{ routes.cart_url }}" method="post" class="contact-form">
      <div class="form-row">
        <div class="form-group">
          <label for="contact-name">{{ section.settings.label_name }}</label>
          <input type="text" id="contact-name" name="contact[name]" required>
        </div>
        <div class="form-group">
          <label for="contact-email">{{ section.settings.label_email }}</label>
          <input type="email" id="contact-email" name="contact[email]" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="contact-company">{{ section.settings.label_company }}</label>
          <input type="text" id="contact-company" name="contact[company]" placeholder="Brand or retail store name">
        </div>
        <div class="form-group">
          <label for="contact-phone">{{ section.settings.label_phone }}</label>
          <input type="tel" id="contact-phone" name="contact[phone]" placeholder="+1 (555) 000-0000">
        </div>
      </div>

      <div class="form-group">
        <label for="contact-inquiry">{{ section.settings.label_inquiry }}</label>
        <select id="contact-inquiry" name="contact[inquiry_type]" required>
          <option value="">Select inquiry type...</option>
          <option value="samples">Request samples</option>
          <option value="pricing">Pricing and MOQ</option>
          <option value="custom">Custom formulation</option>
          <option value="packaging">Private label packaging</option>
          <option value="other">Other inquiry</option>
        </select>
      </div>

      <div class="form-group">
        <label for="contact-message">{{ section.settings.label_message }}</label>
        <textarea id="contact-message" name="contact[body]" placeholder="Tell us about your project..." required></textarea>
      </div>

      <button type="submit" class="contact-submit">{{ section.settings.button_text }}</button>
      <p class="contact-note">We'll respond within 24 hours with product details and pricing.</p>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a quote or samples" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Tell us about your whitening brand and what you're building. Our team will follow up within 24 hours." },
    { "type": "text", "id": "label_name", "label": "Name field label", "default": "Full name" },
    { "type": "text", "id": "label_email", "label": "Email field label", "default": "Email address" },
    { "type": "text", "id": "label_company", "label": "Company field label", "default": "Brand / Company" },
    { "type": "text", "id": "label_phone", "label": "Phone field label", "default": "Phone" },
    { "type": "text", "id": "label_inquiry", "label": "Inquiry type label", "default": "Inquiry type" },
    { "type": "text", "id": "label_message", "label": "Message field label", "default": "Project details" },
    { "type": "text", "id": "button_text", "label": "Submit button text", "default": "Send inquiry" }
  ]
}
{% endschema %}

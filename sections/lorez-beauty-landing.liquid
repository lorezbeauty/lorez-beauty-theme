<!-- sections/lorez-beauty-landing.liquid -->
<style>
  #lorez-landing-{{ section.id }} {
    font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: linear-gradient(180deg, #fffaf8 0%, #fff 100%);
    color: #2f2326;
    width: 100%;
    overflow-x: hidden;
  }

  #lorez-landing-{{ section.id }} .lz-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }

  #lorez-landing-{{ section.id }} .lz-heading {
    font-family: Poppins, Inter, sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #lorez-landing-{{ section.id }} .lz-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 14px 24px;
    font-weight: 600;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  #lorez-landing-{{ section.id }} .lz-btn:hover {
    transform: translateY(-2px);
  }

  #lorez-landing-{{ section.id }} .lz-hero {
    position: relative;
    overflow: hidden;
    padding: 72px 0 54px;
    background: linear-gradient(120deg, #f8e8e5 0%, #f6c9cd 45%, #e68f9f 100%);
    color: #fff;
  }

  #lorez-landing-{{ section.id }} .lz-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0) 34%);
    pointer-events: none;
  }

  #lorez-landing-{{ section.id }} .lz-hero__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 32px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  #lorez-landing-{{ section.id }} .lz-hero__copy {
    max-width: 680px;
  }

  #lorez-landing-{{ section.id }} .lz-eyebrow {
    display: inline-block;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255,255,255,0.2);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  #lorez-landing-{{ section.id }} .lz-hero h1 {
    font-size: clamp(2.4rem, 4.4vw, 4rem);
    line-height: 1.02;
    margin-bottom: 18px;
  }

  #lorez-landing-{{ section.id }} .lz-hero p {
    font-size: 1.02rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.95);
    max-width: 590px;
  }

  #lorez-landing-{{ section.id }} .lz-hero__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  #lorez-landing-{{ section.id }} .lz-hero__actions .lz-btn--light {
    background: #fff;
    color: #bc5168;
    box-shadow: 0 14px 30px rgba(116, 45, 55, 0.15);
  }

  #lorez-landing-{{ section.id }} .lz-hero__actions .lz-btn--ghost {
    border: 1px solid rgba(255,255,255,0.7);
    color: #fff;
    background: rgba(255,255,255,0.08);
  }

  #lorez-landing-{{ section.id }} .lz-hero__panel {
    background: rgba(255,255,255,0.95);
    border-radius: 28px;
    padding: 24px;
    color: #4a2f32;
    box-shadow: 0 20px 50px rgba(88, 40, 47, 0.16);
  }

  #lorez-landing-{{ section.id }} .lz-hero__panel h3 {
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  #lorez-landing-{{ section.id }} .lz-hero__panel ul {
    display: grid;
    gap: 10px;
    font-size: 0.95rem;
    color: #6c4f55;
  }

  #lorez-landing-{{ section.id }} .lz-trust-row {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    padding: 24px 0;
    background: #fff;
  }

  #lorez-landing-{{ section.id }} .lz-trust-pill {
    padding: 10px 16px;
    border-radius: 999px;
    background: #fff8f7;
    color: #83555d;
    font-size: 0.9rem;
    border: 1px solid #f2dfe3;
  }

  #lorez-landing-{{ section.id }} .lz-section {
    padding: 72px 0;
  }

  #lorez-landing-{{ section.id }} .lz-section__head {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 32px;
  }

  #lorez-landing-{{ section.id }} .lz-section__head .lz-eyebrow {
    color: #c96c7e;
    background: #fff1f3;
    margin-bottom: 14px;
  }

  #lorez-landing-{{ section.id }} .lz-section__head h2 {
    font-size: clamp(1.8rem, 3vw, 2.45rem);
    margin-bottom: 10px;
    color: #342125;
  }

  #lorez-landing-{{ section.id }} .lz-section__head p {
    color: #7a5d64;
    line-height: 1.7;
  }

  #lorez-landing-{{ section.id }} .lz-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }

  #lorez-landing-{{ section.id }} .lz-card {
    background: #fff;
    border: 1px solid #f1e2e7;
    border-radius: 24px;
    padding: 22px;
    box-shadow: 0 16px 32px rgba(125, 66, 76, 0.08);
  }

  #lorez-landing-{{ section.id }} .lz-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ffdfe7, #f5bac4);
    font-size: 1.25rem;
    margin-bottom: 10px;
  }

  #lorez-landing-{{ section.id }} .lz-card h3 {
    font-size: 1.08rem;
    margin-bottom: 8px;
    color: #332427;
  }

  #lorez-landing-{{ section.id }} .lz-card p {
    color: #7b6066;
    line-height: 1.65;
    font-size: 0.95rem;
  }

  #lorez-landing-{{ section.id }} .lz-product-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 100%;
  }

  #lorez-landing-{{ section.id }} .lz-product-badge {
    display: inline-flex;
    width: fit-content;
    padding: 6px 10px;
    border-radius: 999px;
    background: #fff3f5;
    color: #c56a7d;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  #lorez-landing-{{ section.id }} .lz-product-card h3 {
    font-size: 1.1rem;
    color: #312427;
  }

  #lorez-landing-{{ section.id }} .lz-product-card .lz-price {
    font-size: 1.05rem;
    font-weight: 700;
    color: #b84f68;
  }

  #lorez-landing-{{ section.id }} .lz-product-card .lz-cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    border-radius: 999px;
    background: #b84f68;
    color: #fff;
    padding: 10px 16px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  #lorez-landing-{{ section.id }} .lz-cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  #lorez-landing-{{ section.id }} .lz-stats {
    background: linear-gradient(135deg, #fff6f8 0%, #fbe5ea 100%);
    border-radius: 28px;
    padding: 34px;
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    margin-top: 24px;
  }

  #lorez-landing-{{ section.id }} .lz-stat strong {
    display: block;
    font-size: 1.65rem;
    color: #b84f68;
  }

  #lorez-landing-{{ section.id }} .lz-testimonial {
    background: #fff;
    border: 1px solid #f1e2e7;
    border-radius: 20px;
    padding: 22px;
  }

  #lorez-landing-{{ section.id }} .lz-testimonial .lz-stars {
    color: #f3b451;
    letter-spacing: 0.15em;
    margin-bottom: 8px;
  }

  @media (max-width: 900px) {
    #lorez-landing-{{ section.id }} .lz-hero__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 749px) {
    #lorez-landing-{{ section.id }} .lz-hero {
      padding: 54px 0 36px;
    }

    #lorez-landing-{{ section.id }} .lz-section {
      padding: 56px 0;
    }
  }
</style>

<div id="lorez-landing-{{ section.id }}">
  <section class="lz-hero">
    <div class="lz-shell lz-hero__grid">
      <div class="lz-hero__copy">
        {%- if section.settings.eyebrow != blank -%}
          <div class="lz-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h1 class="lz-heading">{{ section.settings.hero_heading }}</h1>
        <p>{{ section.settings.hero_subheading }}</p>
        <div class="lz-hero__actions">
          {%- if section.settings.button_1_text != blank -%}
            <a href="{{ section.settings.button_1_link }}" class="lz-btn lz-btn--light">{{ section.settings.button_1_text }}</a>
          {%- endif -%}
          {%- if section.settings.button_2_text != blank -%}
            <a href="{{ section.settings.button_2_link }}" class="lz-btn lz-btn--ghost">{{ section.settings.button_2_text }}</a>
          {%- endif -%}
        </div>
      </div>
      <div class="lz-hero__panel">
        <h3 class="lz-heading">OEM / ODM whitening solutions</h3>
        <ul>
          <li>• Custom formulas with PAP, HP, SC and non-peroxide options</li>
          <li>• Fast sampling, low MOQ and private label packaging</li>
          <li>• Factory-direct supply with certifications and predictable lead times</li>
        </ul>
      </div>
    </div>
  </section>

  {%- assign trust_blocks = section.blocks | where: "type", "trust_item" -%}
  {%- if trust_blocks.size > 0 -%}
    <div class="lz-trust-row">
      {%- for block in trust_blocks -%}
        <div class="lz-trust-pill">{{ block.settings.label }}</div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <section class="lz-section" id="customization">
    <div class="lz-shell">
      <div class="lz-section__head">
        <div class="lz-eyebrow">Customization</div>
        <h2 class="lz-heading">Build a whitening line that matches your brand</h2>
        <p>From strips and gels to powders, LED kits and private label packaging, every format can be tailored to your audience, claims and retail experience.</p>
      </div>
      <div class="lz-grid">
        <div class="lz-card">
          <div class="lz-card__icon">🧪</div>
          <h3>Formula customization</h3>
          <p>Select from PAP, HP, SC and non-peroxide concepts, or bring your own formula with a factory-ready development path.</p>
        </div>
        <div class="lz-card">
          <div class="lz-card__icon">🍓</div>
          <h3>Taste and aroma</h3>
          <p>Craft a more premium experience with fruit, floral or mint-inspired flavor profiles that sit comfortably with your brand.</p>
        </div>
        <div class="lz-card">
          <div class="lz-card__icon">🦷</div>
          <h3>Strip and applicator molds</h3>
          <p>Choose machine or hand-crafted mold workflows for efficiency, volume and a more distinctive product experience.</p>
        </div>
        <div class="lz-card">
          <div class="lz-card__icon">📦</div>
          <h3>Packaging design</h3>
          <p>Match the retail finish, carton format and material mix to your visual identity with flexible packaging options.</p>
        </div>
      </div>
    </div>
  </section>

  {%- assign product_blocks = section.blocks | where: "type", "product" -%}
  {%- if product_blocks.size > 0 -%}
    <section class="lz-section" id="products">
      <div class="lz-shell">
        <div class="lz-section__head">
          <div class="lz-eyebrow">Product range</div>
          <h2 class="lz-heading">Featured whitening products for your shop</h2>
          <p>These lines are designed for fast-moving retail launches, private label growth and customer-friendly whitening routines.</p>
        </div>
        <div class="lz-grid">
          {%- for block in product_blocks -%}
            {%- assign p = block.settings.product -%}
            <div class="lz-card lz-product-card" {{ block.shopify_attributes }}>
              <div class="lz-product-badge">{{ block.settings.tag | default: 'Featured' }}</div>
              <h3 class="lz-heading">{{ p.title | default: block.settings.fallback_name }}</h3>
              <p>{{ block.settings.description | default: p.description | strip_html | truncatewords: 20 }}</p>
              <div class="lz-price">{%- if p != blank -%}{{ p.price | money }}{%- else -%}{{ block.settings.fallback_price }}{%- endif -%}</div>
              <div class="lz-cta-row">
                <a href="{{ p.url | default: '/collections/all' }}" class="lz-cta">View product</a>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="lz-section">
    <div class="lz-shell">
      <div class="lz-section__head">
        <div class="lz-eyebrow">Why brands choose us</div>
        <h2 class="lz-heading">Factory capabilities and compliance in one place</h2>
        <p>Scale confidently with a team that can support prototype development, technical validation and fast production without sacrificing quality.</p>
      </div>
      <div class="lz-stats">
        <div class="lz-stat">
          <strong>72M+</strong>
          <span>Annual production capacity</span>
        </div>
        <div class="lz-stat">
          <strong>20+</strong>
          <span>R&D specialists and product engineers</span>
        </div>
        <div class="lz-stat">
          <strong>GMP</strong>
          <span>ISO, CE and SGS aligned manufacturing</span>
        </div>
        <div class="lz-stat">
          <strong>Low MOQ</strong>
          <span>Fast sampling and custom packaging support</span>
        </div>
      </div>
    </div>
  </section>

  {%- assign testimonial_blocks = section.blocks | where: "type", "testimonial" -%}
  {%- if testimonial_blocks.size > 0 -%}
    <section class="lz-section">
      <div class="lz-shell">
        <div class="lz-section__head">
          <div class="lz-eyebrow">Client feedback</div>
          <h2 class="lz-heading">{{ section.settings.testimonials_heading }}</h2>
        </div>
        <div class="lz-grid">
          {%- for block in testimonial_blocks -%}
            <div class="lz-testimonial" {{ block.shopify_attributes }}>
              <div class="lz-stars">{%- for i in (1..5) -%}{%- if i <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}</div>
              <p>{{ block.settings.quote }}</p>
              <strong style="display:block; margin-top:10px; color:#342125;">{{ block.settings.name }}</strong>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- if section.settings.show_newsletter -%}
    <section class="lz-section" style="padding-top: 0;">
      <div class="lz-shell">
        <div style="background: linear-gradient(90deg, #b84f68 0%, #d16b7b 100%); border-radius: 28px; padding: 40px 28px; color: #fff; text-align: center;">
          <div class="lz-eyebrow" style="background: rgba(255,255,255,0.18); color: #fff;">Launch support</div>
          <h2 class="lz-heading" style="font-size: 1.9rem; margin-bottom: 10px;">{{ section.settings.newsletter_heading }}</h2>
          <p style="max-width: 640px; margin: 0 auto 20px; line-height: 1.7; color: rgba(255,255,255,0.92);">{{ section.settings.newsletter_subheading }}</p>
          {%- form 'customer' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div style="display:flex; justify-content:center; gap:12px; flex-wrap:wrap; max-width:440px; margin:0 auto;">
              <input type="email" name="contact[email]" placeholder="jouw@email.com" required style="flex:1; min-width:220px; border: 0; border-radius:999px; padding: 13px 18px; font-size: 0.95rem;">
              <button type="submit" style="border:0; border-radius:999px; padding: 13px 20px; background:#fff; color:#b84f68; font-weight:700;">Aanmelden</button>
            </div>
          {%- endform -%}
        </div>
      </div>
    </section>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Lorez Beauty Landing",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow tekst", "default": "FACTORY DIRECT • PRIVATE LABEL" },
    { "type": "text", "id": "hero_heading", "label": "Hero titel", "default": "Private label teeth whitening products for modern beauty brands" },
    { "type": "textarea", "id": "hero_subheading", "label": "Hero subtekst", "default": "OEM and ODM solutions for whitening strips, gels, powders, LED kits and custom packaging built for retail growth." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero afbeelding (fallback/poster)" },
    { "type": "video", "id": "hero_video", "label": "Hero video (heeft voorrang op afbeelding)" },
    { "type": "text", "id": "button_1_text", "label": "Knop 1 tekst", "default": "Request a quote" },
    { "type": "url", "id": "button_1_link", "label": "Knop 1 link" },
    { "type": "text", "id": "button_2_text", "label": "Knop 2 tekst", "default": "Bekijk producten" },
    { "type": "url", "id": "button_2_link", "label": "Knop 2 link" },

    { "type": "header", "content": "Productsectie" },
    { "type": "text", "id": "collection_eyebrow", "label": "Eyebrow", "default": "Product range" },
    { "type": "text", "id": "collection_heading", "label": "Titel", "default": "Featured whitening products for your shop" },

    { "type": "header", "content": "Resultaten" },
    { "type": "checkbox", "id": "show_results", "label": "Toon resultaten-sectie", "default": true },
    { "type": "text", "id": "results_eyebrow", "label": "Eyebrow", "default": "Why brands choose us" },
    { "type": "text", "id": "results_heading", "label": "Titel", "default": "Factory capabilities and compliance in one place" },
    { "type": "textarea", "id": "results_text", "label": "Tekst", "default": "Speed, flexibility and compliant manufacturing are the core of every private label whitening launch." },
    { "type": "image_picker", "id": "results_image", "label": "Voor/na afbeelding" },
    { "type": "text", "id": "stat_1_number", "label": "Statistiek 1 getal", "default": "72M+" },
    { "type": "text", "id": "stat_1_label", "label": "Statistiek 1 label", "default": "annual production capacity" },
    { "type": "text", "id": "stat_2_number", "label": "Statistiek 2 getal", "default": "20+" },
    { "type": "text", "id": "stat_2_label", "label": "Statistiek 2 label", "default": "R&D specialists" },

    { "type": "header", "content": "Testimonials" },
    { "type": "text", "id": "testimonials_heading", "label": "Titel", "default": "What clients say" },

    { "type": "header", "content": "Nieuwsbrief" },
    { "type": "checkbox", "id": "show_newsletter", "label": "Toon nieuwsbrief-sectie", "default": true },
    { "type": "text", "id": "newsletter_heading", "label": "Titel", "default": "Launch support for your next product line" },
    { "type": "textarea", "id": "newsletter_subheading", "label": "Subtekst", "default": "Receive product guidance, launch tips and sample support for your private label whitening brand." }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Vertrouwenspunt",
      "settings": [
        { "type": "text", "id": "label", "label": "Tekst", "default": "Dermatologisch getest" }
      ]
    },
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Koppel Shopify product" },
        { "type": "text", "id": "tag", "label": "Label", "default": "Bestseller" },
        { "type": "textarea", "id": "description", "label": "Omschrijving" },
        { "type": "text", "id": "fallback_name", "label": "Naam", "default": "Productnaam" },
        { "type": "text", "id": "fallback_price", "label": "Prijs", "default": "€ 0,00" }
      ]
    },
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "The launch became easier with a strong OEM partner and faster customization." },
        { "type": "text", "id": "name", "label": "Naam", "default": "Fleur, 27" },
        { "type": "image_picker", "id": "avatar", "label": "Foto" },
        { "type": "range", "id": "rating", "label": "Sterren", "min": 1, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lorez Beauty Landing",
      "blocks": [
        { "type": "trust_item", "settings": { "label": "Dermatologisch getest" } },
        { "type": "trust_item", "settings": { "label": "Vegan en cruelty-free" } },
        { "type": "trust_item", "settings": { "label": "Peroxide-arme formule" } },
        { "type": "trust_item", "settings": { "label": "30 dagen niet-goed-geld-terug" } },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "testimonial", "settings": { "quote": "The launch became easier with a strong OEM partner and faster customization.", "name": "Lina, 31", "rating": 5 } },
        { "type": "testimonial", "settings": { "quote": "We launched a premium line in weeks instead of months.", "name": "Mila, 35", "rating": 5 } }
      ]
    }
  ]
}
{% endschema %}

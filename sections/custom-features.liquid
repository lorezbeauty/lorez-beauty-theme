<section class="smile-benefits" id="{{ section.settings.section_id | default: 'benefits' }}">
  <div class="smile-benefits__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow smile-benefits__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="heading-lg smile-benefits__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="smile-benefits__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <div class="smile-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="smile-benefit-card" {{ block.shopify_attributes }}>
          {%- if block.settings.image_asset != blank -%}
            <div class="smile-benefit-card__visual">
              <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ block.settings.title }}" loading="lazy" width="120" height="120" class="smile-benefit-card__photo">
            </div>
          {%- elsif block.settings.icon != blank -%}
            <div class="smile-benefit-card__icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h4>{{ block.settings.title }}</h4>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p>{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom features",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "section_id", "label": "Section HTML ID", "default": "benefits" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Lorez Beauty" },
    { "type": "text", "id": "title", "label": "Title", "default": "Built for your brand from start to finish" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Every element of your whitening product can be adjusted to your brand needs." }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature card",
      "settings": [
        { "type": "text", "id": "image_asset", "label": "Product image asset (optional)", "info": "Theme asset filename — overrides emoji when set" },
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🧪" },
        { "type": "text", "id": "title", "label": "Title", "default": "Formula" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "PAP, carbamide peroxide, charcoal and sensitivity-free options." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom features",
      "blocks": [
        { "type": "card", "settings": { "icon": "🧪", "title": "Formula", "text": "PAP, carbamide peroxide, charcoal and sensitivity-free options." } },
        { "type": "card", "settings": { "icon": "🌿", "title": "Taste & Scent", "text": "Mint, bubblegum, coconut and custom flavors for your audience." } },
        { "type": "card", "settings": { "icon": "🗂", "title": "Mold & Shape", "text": "Standard or fully custom strip shapes, trays and applicators." } },
        { "type": "card", "settings": { "icon": "📦", "title": "Packaging", "text": "Retail-ready boxes, sachets and eco-friendly options." } }
      ]
    }
  ]
}
{% endschema %}

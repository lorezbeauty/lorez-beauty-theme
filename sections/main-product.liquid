<div class="product-page">
  <div class="product-page__grid">
    <div class="product-page__gallery" data-product-gallery>
      {%- if product.media.size > 0 -%}
        <div class="product-gallery__main">
          {%- for media in product.media -%}
            {%- if forloop.first -%}
              {%- assign loading_mode = 'eager' -%}
            {%- else -%}
              {%- assign loading_mode = 'lazy' -%}
            {%- endif -%}
            <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide data-index="{{ forloop.index0 }}">
              {%- if media.media_type == 'video' -%}
                {{ media | video_tag: class: 'product-gallery__video', controls: true, autoplay: false, loop: true, muted: true }}
              {%- else -%}
                {{ media | image_url: width: 1400 | image_tag: loading: loading_mode, sizes: '50vw', class: 'product-gallery__img' }}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs" role="tablist" aria-label="Gallery">
            {%- for media in product.media -%}
              <button
                type="button"
                class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-gallery-thumb
                data-index="{{ forloop.index0 }}"
                aria-label="Image {{ forloop.index }}"
              >
                {%- if media.media_type == 'video' -%}
                  <span class="product-gallery__thumb-video">▶</span>
                  {{ media.preview_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ media | image_url: width: 120 | image_tag: loading: 'lazy' }}
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="product-page__info">
      {%- render 'product-routine-meta', product: product -%}

      {%- if routine_step != blank -%}
        <p class="product-page__step eyebrow">{{ routine_step }}</p>
      {%- endif -%}

      <h1 class="product-page__title heading-lg">{{ product.title }}</h1>

      {%- if routine_tagline != blank -%}
        <p class="product-page__tagline">{{ routine_tagline }}</p>
      {%- endif -%}

      {%- assign price_eur = product.price | times: 1.0 | divided_by: 100.0 -%}
      <p class="product-page__price" data-price data-price-eur="{{ price_eur }}">{{ product.price | money }}</p>

      {%- if routine_ingredients != blank -%}
        <div class="product-page__specs">
          <span class="product-page__spec">🧪 {{ routine_ingredients }}</span>
          <span class="product-page__spec">✓ Cruelty-free</span>
          <span class="product-page__spec">✓ All skin types</span>
        </div>
      {%- endif -%}

      <ul class="product-page__trust">
        <li>🚚 Free shipping from €50</li>
        <li>↩️ 30-day returns</li>
        <li>🎁 Code <strong>LOREZ</strong>: buy 2 get 1 free</li>
      </ul>

      {% render 'product-acne-demo', product: product %}

      {% form 'product', product, class: 'product-page__form', id: 'product-form' %}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign hide_option = false -%}
            {%- if option.name == 'Title' and option.values.size == 1 and option.values[0] == 'Default Title' -%}
              {%- assign hide_option = true -%}
            {%- endif -%}
            {%- if option.name == 'Color' and option.values.size == 1 and option.values[0] == 'Default Title' -%}
              {%- assign hide_option = true -%}
            {%- endif -%}
            {%- if option.name == 'Specifications' -%}
              {%- assign hide_option = true -%}
            {%- endif -%}
            {%- unless hide_option -%}
              <div class="product-page__option">
                <label class="eyebrow">{{ option.name }}</label>
                <select name="options[{{ option.name | escape }}]" class="product-page__select">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endunless -%}
          {%- endfor -%}
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>

        <button
          type="submit"
          class="btn btn--filled product-page__add"
          {% unless product.available %}disabled{% endunless %}
        >
          {%- if product.available -%}
            {{ 'products.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.sold_out' | t }}
          {%- endif -%}
        </button>
      {% endform %}

      {%- if product.description != blank -%}
        <div class="product-page__description rte">
          {% render 'product-description-clean', product: product %}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "settings": []
}
{% endschema %}

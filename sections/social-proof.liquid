<section class="social-proof">
  <div class="social-proof__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow social-proof__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="heading-lg social-proof__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    <div class="social-proof__stats">
      {%- if section.settings.stat_1 != blank -%}
        <div class="social-proof__stat">
          <p class="social-proof__stat-num">{{ section.settings.stat_1 }}</p>
          <p class="social-proof__stat-label">{{ section.settings.stat_1_label }}</p>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_2 != blank -%}
        <div class="social-proof__stat">
          <p class="social-proof__stat-num">{{ section.settings.stat_2 }}</p>
          <p class="social-proof__stat-label">{{ section.settings.stat_2_label }}</p>
        </div>
      {%- endif -%}
      {%- if section.settings.stat_3 != blank -%}
        <div class="social-proof__stat">
          <p class="social-proof__stat-num">{{ section.settings.stat_3 }}</p>
          <p class="social-proof__stat-label">{{ section.settings.stat_3_label }}</p>
        </div>
      {%- endif -%}
    </div>
    <div class="social-proof__reviews">
      {%- for block in section.blocks -%}
        <blockquote class="social-proof__review" {{ block.shopify_attributes }}>
          <p class="social-proof__stars">★★★★★</p>
          <p class="social-proof__quote">"{{ block.settings.quote }}"</p>
          <footer class="social-proof__author">— {{ block.settings.author }}{% if block.settings.location != blank %}, {{ block.settings.location }}{% endif %}</footer>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social proof",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Resultados reales" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Miles de mujeres ya confían en Lorez" },
    { "type": "text", "id": "stat_1", "label": "Stat 1 number", "default": "4.8/5" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Valoración media" },
    { "type": "text", "id": "stat_2", "label": "Stat 2 number", "default": "2.400+" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Clientas en España y México" },
    { "type": "text", "id": "stat_3", "label": "Stat 3 number", "default": "93%" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Notan piel más limpia en 14 días" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote" },
        { "type": "text", "id": "author", "label": "Author", "default": "María G." },
        { "type": "text", "id": "location", "label": "Location", "default": "Madrid" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Social proof",
      "blocks": [
        { "type": "review", "settings": { "quote": "La mascarilla de oro eliminó mis puntos negros. Mi piel nunca se había visto tan limpia.", "author": "Lucía R.", "location": "Barcelona" } },
        { "type": "review", "settings": { "quote": "Compré el kit completo. En 3 semanas menos granos y poros más cerrados. Vale cada euro.", "author": "Ana M.", "location": "Ciudad de México" } },
        { "type": "review", "settings": { "quote": "Los discos tónicos son lo mejor para mi piel grasa. Por fin una rutina que funciona.", "author": "Carmen S.", "location": "Valencia" } }
      ]
    }
  ]
}
{% endschema %}

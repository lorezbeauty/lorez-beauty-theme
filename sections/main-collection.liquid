<div class="collection-header">
  <div class="collection-hero">
    <div class="collection-hero__content">
      <p class="eyebrow">Private label whitening</p>
      <h1 class="collection-header__title heading-xl">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection-header__description">{{ collection.description }}</div>
      {%- else -%}
        <div class="collection-header__description">Explore premium whitening strips, gels, powders and LED kits designed for modern beauty brands and fast retail launches.</div>
      {%- endif -%}
    </div>
    <div class="collection-hero__card">
      <h3>Fast launch support</h3>
      <p>Low MOQ, free samples, private label packaging and flexible OEM/ODM development for your next line.</p>
    </div>
  </div>
</div>

<div class="collection-grid">
  {%- for product in collection.products -%}
    {% render 'product-card', product: product %}
  {%- else -%}
    <p style="grid-column:1/-1;text-align:center;padding:48px;color:var(--color-warm-gray);">No products found.</p>
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Collection products",
  "tag": "section",
  "settings": []
}
{% endschema %}

<section class="routine-steps" id="{{ section.settings.section_id | default: 'routine' }}">
  <div class="routine-steps__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow routine-steps__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="heading-lg">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="routine-steps__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>
  <div class="routine-steps__grid routine-steps__grid--{{ section.blocks.size }}">
    {%- for block in section.blocks -%}
      <div class="routine-step" {{ block.shopify_attributes }}>
        {%- if block.settings.step_num != blank -%}
          <p class="routine-step__num">{{ block.settings.step_num }}</p>
        {%- endif -%}
        {%- if block.settings.time != blank -%}
          <p class="routine-step__time">{{ block.settings.time }}</p>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h3 class="routine-step__title">{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.description != blank -%}
          <p class="routine-step__desc">{{ block.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Routine steps",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section HTML ID",
      "default": "routine"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Tu ritual diario"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "6 pasos para una piel limpia y equilibrada"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Morning, night & weekly — formulated for oily, acne-prone skin"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "step_num", "label": "Step label", "default": "STEP 01" },
        { "type": "text", "id": "time", "label": "Frequency", "default": "Morning & night" },
        { "type": "text", "id": "title", "label": "Title", "default": "Cleanse" },
        { "type": "text", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Routine steps",
      "blocks": [
        { "type": "step", "settings": { "step_num": "STEP 01", "time": "Morning & night", "title": "Cleanse", "description": "Tea tree gel cleanser. Deep clean without drying." } },
        { "type": "step", "settings": { "step_num": "STEP 02", "time": "Morning & night", "title": "Refine pores", "description": "Korean toner pads. Control sebum and gently exfoliate." } },
        { "type": "step", "settings": { "step_num": "STEP 03", "time": "Morning & night", "title": "Soothe", "description": "Centella set. Reduces redness and acne inflammation." } },
        { "type": "step", "settings": { "step_num": "STEP 04", "time": "Morning & night", "title": "Hydrate", "description": "Collagen cream. Firmness without clogging pores." } },
        { "type": "step", "settings": { "step_num": "STEP 05", "time": "1× per week", "title": "Blackheads", "description": "Gold peel-off mask. Removes impurities on peel-off." } },
        { "type": "step", "settings": { "step_num": "STEP 06", "time": "1× per week", "title": "Luxury ritual", "description": "Collagen mask with brush. Spa experience at home." } }
      ]
    }
  ]
}
{% endschema %}

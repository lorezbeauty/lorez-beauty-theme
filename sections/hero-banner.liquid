<section
  class="hero"
  style="
    --hero-focal-x: {{ section.settings.focal_x }}%;
    --hero-focal-y: {{ section.settings.focal_y }}%;
    --hero-focal-x-mobile: {{ section.settings.focal_x_mobile }}%;
    --hero-focal-y-mobile: {{ section.settings.focal_y_mobile }}%;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>

  <div class="hero__media">

    {%- if section.settings.video != blank -%}

      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'hero__bg' }}

    {%- elsif section.settings.image != blank -%}

      <picture class="hero__picture">
        {%- if section.settings.image_mobile != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="{{ section.settings.image_mobile | image_url: width: 1400 }}"
          >
        {%- endif -%}
        {{
          section.settings.image
          | image_url: width: 2000
          | image_tag:
            loading: 'eager',
            sizes: '100vw',
            alt: section.settings.title,
            class: 'hero__bg'
        }}
      </picture>

    {%- else -%}

      {%- assign collage = section.settings.background_asset | default: 'hero-products-collage.jpg' -%}
      {%- assign collage_mobile = section.settings.background_asset_mobile | default: collage -%}
      {%- assign has_mobile_bg = false -%}

      {%- if section.settings.image_mobile != blank -%}
        {%- assign has_mobile_bg = true -%}
        {{
          section.settings.image_mobile
          | image_url: width: 1400
          | image_tag:
            loading: 'eager',
            sizes: '100vw',
            alt: section.settings.title,
            class: 'hero__bg hero__bg--mobile'
        }}
      {%- elsif collage_mobile != collage -%}
        {%- assign has_mobile_bg = true -%}
        <img
          src="{{ collage_mobile | asset_url }}"
          alt=""
          class="hero__collage-bg hero__bg hero__bg--mobile"
          loading="eager"
          width="1400"
          height="1800"
        >
      {%- endif -%}

      <img
        src="{{ collage | asset_url }}"
        alt=""
        class="hero__collage-bg hero__bg{% if has_mobile_bg %} hero__bg--desktop{% endif %}"
        loading="eager"
        width="2000"
        height="1125"
      >

    {%- endif -%}

  </div>

  <div class="hero__overlay{% unless section.settings.image != blank or section.settings.video != blank %} hero__overlay--rose{% endunless %}"></div>
  <div class="hero__content">

    {%- if section.settings.eyebrow != blank -%}

      <p class="hero__eyebrow eyebrow">{{ section.settings.eyebrow }}</p>

    {%- endif -%}

    {%- if section.settings.title != blank -%}

      <h1 class="hero__title heading-display">{{ section.settings.title }}</h1>

    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}

      <p class="hero__subtitle">{{ section.settings.subtitle }}</p>

    {%- endif -%}

    {%- if section.settings.trust_line != blank -%}

      <p class="hero__trust">{{ section.settings.trust_line }}</p>

    {%- endif -%}

    <div class="hero__actions">

      {%- if section.settings.button_label != blank -%}

        <a href="{{ section.settings.button_link }}" class="btn btn--white btn--lg">

          {%- if section.settings.kit_price_eur != blank -%}

            {{ section.settings.button_label }} — €{{ section.settings.kit_price_eur }}

          {%- else -%}

            {{ section.settings.button_label }}

          {%- endif -%}

        </a>

      {%- endif -%}

      {%- if section.settings.button_secondary_label != blank -%}

        <a href="{{ section.settings.button_secondary_link }}" class="btn btn--ghost-white">

          {{ section.settings.button_secondary_label }}

        </a>

      {%- endif -%}

    </div>

  </div>

</section>



{% schema %}

{

  "name": "Hero banner",

  "tag": "section",

  "class": "section-hero",

  "settings": [

    {

      "type": "image_picker",

      "id": "image",

      "label": "Background image"

    },

    {

      "type": "video",

      "id": "video",

      "label": "Background video"

    },

    {

      "type": "header",

      "content": "Product collage (when no background image)"

    },

    {

      "type": "text",

      "id": "background_asset",

      "label": "Hero collage asset filename",

      "default": "hero-products-collage.jpg",

      "info": "Full-bleed product collage behind rose overlay"

    },

    {

      "type": "text",

      "id": "background_asset_mobile",

      "label": "Mobile collage asset filename",

      "info": "Optional portrait crop for phones. Leave blank to reuse desktop collage."

    },

    {

      "type": "image_picker",

      "id": "image_mobile",

      "label": "Mobile background image",

      "info": "Overrides collage on screens under 750px. Upload a tighter crop for best results."

    },

    {

      "type": "header",

      "content": "Image framing"

    },

    {

      "type": "range",

      "id": "focal_x",

      "label": "Desktop focus — horizontal",

      "min": 0,

      "max": 100,

      "step": 1,

      "unit": "%",

      "default": 50

    },

    {

      "type": "range",

      "id": "focal_y",

      "label": "Desktop focus — vertical",

      "min": 0,

      "max": 100,

      "step": 1,

      "unit": "%",

      "default": 42

    },

    {

      "type": "range",

      "id": "focal_x_mobile",

      "label": "Mobile focus — horizontal",

      "min": 0,

      "max": 100,

      "step": 1,

      "unit": "%",

      "default": 50

    },

    {

      "type": "range",

      "id": "focal_y_mobile",

      "label": "Mobile focus — vertical",

      "min": 0,

      "max": 100,

      "step": 1,

      "unit": "%",

      "default": 48

    },

    {

      "type": "range",

      "id": "overlay_opacity",

      "label": "Overlay strength",

      "min": 50,

      "max": 100,

      "step": 5,

      "unit": "%",

      "default": 90,

      "info": "Higher = darker overlay, better text contrast"

    },

    {

      "type": "text",

      "id": "eyebrow",

      "label": "Eyebrow text",

      "default": "Lorez Beauty"

    },

    {

      "type": "text",

      "id": "title",

      "label": "Heading",

      "default": "A golden escape under the sun"

    },

    {

      "type": "text",

      "id": "subtitle",

      "label": "Subheading",

      "default": "Discover the summer collection"

    },

    {

      "type": "text",

      "id": "trust_line",

      "label": "Trust line under subtitle",

      "default": "★★★★★ 4.8/5 · Free shipping from €50 · 30-day returns"

    },

    {

      "type": "text",

      "id": "kit_price_eur",

      "label": "Kit price (EUR display)",

      "default": "42.95"

    },

    {

      "type": "text",

      "id": "button_label",

      "label": "Primary button label",

      "default": "Discover"

    },

    {

      "type": "text",

      "id": "button_link",

      "label": "Primary button link",

      "default": "/#kit"

    },

    {

      "type": "text",

      "id": "button_secondary_label",

      "label": "Secondary button label"

    },

    {

      "type": "text",

      "id": "button_secondary_link",

      "label": "Secondary button link",

      "default": "/#routine"

    }

  ],

  "presets": [

    {

      "name": "Hero banner"

    }

  ]

}

{% endschema %}



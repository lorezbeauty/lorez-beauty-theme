<section class="faq" id="faq">
  <div class="faq__inner">
    {%- if section.settings.title != blank -%}
      <h2 class="heading-lg faq__title">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.subtitle != blank -%}
      <p class="faq__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <div class="faq__list">
      {%- for block in section.blocks -%}
        <details class="faq__item" {{ block.shopify_attributes }}>
          <summary class="faq__question">{{ block.settings.question }}</summary>
          <div class="faq__answer">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
    {%- if section.settings.button_label != blank -%}
      <div class="faq__cta">
        <a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Answers before you buy" },
    { "type": "text", "id": "button_label", "label": "CTA label", "default": "Start my Clear Skin routine" },
    { "type": "url", "id": "button_link", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "textarea", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "question", "settings": { "question": "Does it work for acne and blackheads?", "answer": "Yes. The Clear Skin routine is designed for oily, acne-prone skin: cleanse, control sebum, calm inflammation and treat blackheads with the gold peel-off mask." } },
        { "type": "question", "settings": { "question": "How long does shipping take?", "answer": "Spain: 7–14 business days. Mexico: 10–18 business days. Free shipping from €50 in Spain and $999 MXN in Mexico." } },
        { "type": "question", "settings": { "question": "What's in the kit?", "answer": "7 essential routine products plus a step-by-step usage guide." } },
        { "type": "question", "settings": { "question": "How does code LOREZ work?", "answer": "Buy 2 products and get 1 free. Enter LOREZ at checkout." } },
        { "type": "question", "settings": { "question": "Can I return if I'm not satisfied?", "answer": "Yes. You have 30 days to return unopened products." } }
      ]
    }
  ]
}
{% endschema %}

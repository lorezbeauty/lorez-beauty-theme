{% if section.settings.show_announcement %}
  <div class="announcement-bar" data-announcement>
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" class="announcement-bar__link">
        {{ section.settings.text }}
      </a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
    <button class="announcement-bar__close" data-announcement-close aria-label="{{ 'accessibility.close' | t }}">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M1 1l12 12M13 1L1 13"/>
      </svg>
    </button>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on all orders"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}

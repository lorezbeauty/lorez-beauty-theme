<div class="page-width" style="padding: calc(var(--header-height) + 48px) var(--gutter) 80px;">
  <h1 class="heading-lg" style="text-align:center;margin-bottom:48px;">{{ 'cart.title' | t }}</h1>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post">
      <div style="max-width:800px;margin:0 auto;">
        {%- for item in cart.items -%}
          <div style="display:grid;grid-template-columns:100px 1fr auto;gap:24px;padding:24px 0;border-bottom:1px solid var(--color-light-gray);align-items:center;">
            {%- if item.image -%}
              {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy', style: 'width:100px;height:120px;object-fit:cover;' }}
            {%- endif -%}
            <div>
              <h3 class="product-card__title">{{ item.product.title }}</h3>
              <p class="product-card__price">{{ item.final_line_price | money }}</p>
            </div>
            <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;text-align:center;border:1px solid var(--color-light-gray);padding:8px;">
          </div>
        {%- endfor -%}

        <div style="text-align:center;margin-top:48px;">
          <p style="font-family:var(--font-serif);font-size:1.5rem;margin-bottom:24px;">{{ cart.total_price | money }}</p>
          <button type="submit" name="update" class="btn" style="margin-right:12px;">Update</button>
          <button type="submit" name="checkout" class="btn btn--filled">{{ 'cart.checkout' | t }}</button>
        </div>
      </div>
    </form>
  {%- else -%}
    <p style="text-align:center;color:var(--color-warm-gray);margin-bottom:32px;">{{ 'cart.empty' | t }}</p>
    <div style="text-align:center;">
      <a href="{{ routes.all_products_collection_url }}" class="btn">{{ 'cart.continue_shopping' | t }}</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}

<article class="product-card">
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__media">
      {%- if product.featured_media -%}
        {{ product.featured_media | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 1024px) 25vw, 50vw' }}
        {%- if product.media.size > 1 -%}
          {{ product.media[1] | image_url: width: 800 | image_tag: loading: 'lazy', sizes: '(min-width: 1024px) 25vw, 50vw' }}
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
    </div>
    <div class="product-card__info">
      {%- if step_label != blank -%}
        <p class="product-card__step">{{ step_label }}</p>
      {%- endif -%}
      <h3 class="product-card__title">{{ product.title }}</h3>
      <p class="product-card__price">
        {%- assign price_eur = product.price | times: 1.0 | divided_by: 100.0 -%}
        <span data-price data-price-eur="{{ price_eur }}">{{ product.price | money }}</span>
      </p>
    </div>
  </a>
  {%- form 'product', product, class: 'product-card__form' -%}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="btn product-card__btn" {% unless product.available %}disabled{% endunless %}>
      {%- if product.available -%}
        {{ 'products.add_to_cart' | t }}
      {%- else -%}
        {{ 'products.sold_out' | t }}
      {%- endif -%}
    </button>
  {%- endform -%}
</article>

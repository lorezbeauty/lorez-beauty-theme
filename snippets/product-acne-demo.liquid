{%- comment -%}Acne solution block — video demo or 3-step routine{%- endcomment -%}
{%- render 'product-routine-meta', product: product -%}
{%- assign show_acne = false -%}
{%- if acne_angle != blank or product.tags contains 'anti-acne' or product.tags contains 'clear-skin' -%}
  {%- assign show_acne = true -%}
{%- endif -%}

{%- if show_acne -%}

{%- assign acne_video = nil -%}
{%- for media in product.media -%}
  {%- if media.media_type == 'video' -%}
    {%- assign acne_video = media -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<section class="product-acne-demo" aria-label="Anti-acne solution">
  <p class="product-acne-demo__eyebrow eyebrow">Clear Skin · Lorez Beauty</p>
  <h2 class="product-acne-demo__title heading-md">How it helps with acne</h2>

  {%- if acne_angle != blank -%}
    <p class="product-acne-demo__lead">{{ acne_angle }}</p>
  {%- else -%}
    <p class="product-acne-demo__lead">A key step in your morning, night or weekly routine for breakouts and visible pores.</p>
  {%- endif -%}

  {%- if acne_video -%}
    <div class="product-acne-demo__video">
      {{ acne_video | video_tag: class: 'product-acne-demo__player', controls: true, autoplay: false, loop: true, muted: true, playsinline: true }}
      <p class="product-acne-demo__caption">▶ Watch how to use it in your daily routine</p>
    </div>
  {%- else -%}
    <ol class="product-acne-demo__steps">
      <li><strong>Cleanse</strong> — remove oil and impurities without irritation.</li>
      <li><strong>Treat</strong> — actives that refine pores and calm redness.</li>
      <li><strong>Protect</strong> — hydrate + SPF to prevent dark marks.</li>
    </ol>
    <p class="product-acne-demo__hint">💡 Upload a demo video in <em>Media</em> (position 2) to show real application.</p>
  {%- endif -%}
</section>
{%- endif -%}

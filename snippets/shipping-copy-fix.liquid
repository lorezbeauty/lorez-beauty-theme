{%- comment -%}
  Normalizes outdated free-shipping copy (€35) to current store policy (€50).
  Usage: {% render 'shipping-copy-fix', html: product.description %}
{%- endcomment -%}
{%- assign fixed = html
  | replace: 'Free shipping from 35 €', 'Free shipping from 50 €'
  | replace: 'Free shipping from 35€', 'Free shipping from 50€'
  | replace: 'free shipping from 35 €', 'free shipping from 50 €'
  | replace: 'free shipping from 35€', 'free shipping from 50€'
  | replace: 'from 35 €', 'from 50 €'
  | replace: 'from 35€', 'from 50€'
  | replace: 'from €35', 'from €50'
  | replace: 'over 35 €', 'over 50 €'
  | replace: 'over 35€', 'over 50€'
  | replace: 'under 35 €', 'under 50 €'
  | replace: 'under 35€', 'under 50€'
  | replace: 'Envío gratuito a partir de 35 €', 'Free shipping from 50 €'
  | replace: 'Envío gratuito a partir de 35€', 'Free shipping from 50€'
  | replace: 'envío gratuito a partir de 35 €', 'free shipping from 50 €'
  | replace: 'envío gratuito a partir de 35€', 'free shipping from 50€'
  | replace: 'a partir de 35 €', 'from 50 €'
  | replace: 'a partir de 35€', 'from 50€'
  | replace: 'desde 35 €', 'from 50 €'
  | replace: 'desde 35€', 'from 50€'
  | replace: 'superiores a 35 €', 'over 50 €'
  | replace: 'superiores a 35€', 'over 50€'
-%}
{{- fixed -}}

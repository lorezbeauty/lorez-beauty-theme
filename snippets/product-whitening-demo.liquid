{%- if whitening_angle != blank -%}
  <div class="product-whitening-demo">
    <p class="product-whitening-demo__lead">{{ whitening_angle }}</p>
    <ol class="product-whitening-demo__steps">
      <li><strong>1.</strong> Dry your teeth</li>
      <li><strong>2.</strong> Apply the strip to upper and lower teeth</li>
      <li><strong>3.</strong> Wait 30 minutes</li>
      <li><strong>4.</strong> Remove — no rinsing needed</li>
    </ol>
  </div>
{%- endif -%}

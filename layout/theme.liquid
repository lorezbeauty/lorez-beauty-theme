<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#9e6b6b">
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {%- if template.name == 'index' -%}
      Lorez Beauty | PAP+ Whitening — Whiter Teeth in 30 Minutes
    {%- else -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags.join(', ') }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains 'Lorez Beauty' %} &ndash; Lorez Beauty{% endunless -%}
    {%- endif -%}
  </title>

  {%- if template.name == 'index' -%}
    <meta name="description" content="Lorez Beauty PAP+ whitening strips — whiter teeth in 30 minutes. No peroxide, no sensitivity. Complete Smile Bundle €42.95. Free shipping from €50.">
  {%- elsif page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Italiana&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.themeSettings = {
      moneyFormat: {{ shop.money_format | json }}
    };
    window.Shopify = window.Shopify || {};
    Shopify.country = {{ localization.country.iso_code | json }};
  </script>
</head>
<body class="template-{{ template.name | handle }}{% if template.suffix %} template-{{ template.name | handle }}-{{ template.suffix }}{% endif %}">
  <a class="skip-link visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  <div class="cart-toast" id="cart-toast">{{ 'cart.added' | t }} · <a href="{{ routes.cart_url }}">{{ 'cart.view' | t }}</a></div>

  {%- if template.name == 'index' -%}
    {% render 'sticky-cta' %}
  {%- endif -%}
</body>
</html>
